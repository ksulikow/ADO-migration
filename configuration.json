{
  "$schema": "https://devopsmigration.io/schema/configuration.schema.json",
  "Serilog": {
    "MinimumLevel": "Information"
  },
  "MigrationTools": {
    "Version": "16.3",
    "Endpoints": {
      "Source": {
        "EndpointType": "TfsTeamProjectEndpoint",
        "Collection": "https://dev.azure.com/Kriss365-Dev/",
        "Project": "ADO-Migration-Test",
        "Authentication": {
          "AuthenticationMode": "AccessToken",
          "NetworkCredentials": {
            "Domain": "",
            "UserName": "",
            "Password": ""
          },
          "AccessToken": "set up your token here"
        },
        "ReflectedWorkItemIdField": "Custom.ReflectedWorkItemId",
        "LanguageMaps": {
          "AreaPath": "Area",
          "IterationPath": "Iteration"
        },
        "ProductVersion": "Cloud"
      },
      "Target": {
        "EndpointType": "TfsTeamProjectEndpoint",
        "Collection": "https://dev.azure.com/Kriss365-Dev/",
        "Project": "ADO-Migration-Test",
        "Authentication": {
          "AuthenticationMode": "AccessToken",
          "NetworkCredentials": {
            "Domain": "",
            "UserName": "",
            "Password": ""
          },
          "AccessToken": "set up your token here"
        },
        "ReflectedWorkItemIdField": "Custom.ReflectedWorkItemId",
        "LanguageMaps": {
          "AreaPath": "Area",
          "IterationPath": "Iteration"
        },
        "ProductVersion": "Cloud"
      }
    },
    "Processors": [
      {
        "ProcessorType": "TfsWorkItemMigrationProcessor",
        "Enabled": true,
        "WIQLQuery": "SELECT [System.Id] FROM WorkItems WHERE [System.TeamProject] = @TeamProject AND [System.WorkItemType] IN ('User Story', 'Feature') ORDER BY [System.ChangedDate] desc",
        "FixHtmlAttachmentLinks": true,
        "WorkItemCreateRetryLimit": 5,
        "FilterWorkItemsThatAlreadyExistInTarget": true,
        "GenerateMigrationComment": true,
        "UpdateCreatedDate": true,
        "UpdateCreatedBy": true,
        "ReplayRevisions": true,
        "SkipRevisionWithInvalidIterationPath": true,
        "SkipRevisionWithInvalidAreaPath": true,
        "MaxGracefulFailures": 0,
        "SourceName": "Source",
        "TargetName": "Target"
      }
    ],
    "CommonTools": {
      "TfsWorkItemTypeValidatorTool": {
        "Enabled": true,
        "IncludeWorkItemTypes": [
          "User Story",
          "User Story New",
          "Feature",
          "Feature New"
        ],
        "ExcludeDefaultWorkItemTypes": false
      },
      "WorkItemTypeMappingTool": {
        "Enabled": true,
        "Mappings": {
          "User Story": "User Story New",
          "Feature": "Feature New"
        }
      },
      "FieldMappingTool": {
        "Enabled": false,
        "FieldMaps": []
      }
    }
  }
}